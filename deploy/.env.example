# vps-scaffold-auth configuration.
# Copy to apps/auth/.env in your server repo and fill in. Never commit the real
# .env — the deploy helper sets it to mode 600 on the server.

# --- Identity / authorization ---
# Public base URL of the auth service (the auth.<domain> site).
AUTH_PUBLIC_URL=https://auth.myserver.example.com
# Comma-separated domains whose verified email holders become regular users.
ALLOWED_EMAIL_DOMAINS=example.com,example.org
# Comma-separated explicit admin emails (granted the "admin" group).
ADMIN_EMAILS=alice@example.com
# Optional "Continue" link shown on the signed-in page when a user logs in
# without a specific app target (e.g. a direct visit to the login page). Such
# logins now land on the auth host's own signed-in page (which always has a valid
# cert); they are NOT auto-redirected here. Must be a served SUBDOMAIN URL — a
# bare apex (https://myserver.example.com) is ignored, since the gateway serves
# subdomains and the apex often has no certificate.
DEFAULT_REDIRECT=https://app.myserver.example.com

# --- Session ---
# 32+ random bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Leading-dot domain so the session is shared across app subdomains.
# IMPORTANT: if DOMAIN is itself a subdomain (vps1.example.com), set this to
# .vps1.example.com — never widen it to a domain you don't fully control.
COOKIE_DOMAIN=.myserver.example.com
SESSION_TTL=2h
# How long before a session slides (renews + re-checks policy/groups). Must be
# less than SESSION_TTL, or a session expires before it can ever renew.
SESSION_RENEW_AFTER=1h
# Lifetime when the user ticks "Keep me signed in" (must be >= SESSION_TTL).
SESSION_REMEMBER_TTL=24h

# --- At-rest secret encryption ---
# Reversible secrets (break-glass tokens, admin TOTP seeds) are encrypted in the
# SQLite file with AES-256-GCM. By default the key is derived from SESSION_SECRET.
# Set a dedicated 32-byte hex key (openssl rand -hex 32) to decouple encryption
# from session signing, so rotating SESSION_SECRET does not require re-encrypting
# stored secrets.
# DATA_ENCRYPTION_KEY=

# --- One-time code ---
OTP_TTL=10m
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# --- Email delivery ---
EMAIL_BACKEND=smtp            # smtp | resend | log (log is for local/dev only)
EMAIL_FROM=Login <auth@example.com>
# Product/site name shown as the wordmark in the sign-in code email. Optional;
# defaults to DOMAIN. The email's accent colour comes from the admin branding
# page (/admin/branding), so it matches the login page.
BRAND_NAME=
# smtp backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# resend backend
RESEND_API_KEY=

# --- Admin two-factor (optional) ---
# When true, admins must enter an authenticator code after the email step.
# Secrets are admin-provisioned, never self-enrolled: bootstrap the first admin
# with `auth -totp-enroll you@example.com` (run in this container), then manage
# the rest from /admin/totp. An admin with no secret is denied at login.
TOTP_ENABLED=false
TOTP_ISSUER=myserver.example.com

# --- Break-the-glass QR codes ---
# Lifetime for a session granted by scanning a break-glass card. These sessions
# are never renewed; they expire at this absolute timeout. This is the default;
# it can also be set at runtime on the admin Settings page.
BREAKGLASS_SESSION_TTL=8h
# Where to send a user after a break-glass grant (defaults to DEFAULT_REDIRECT).
# BREAKGLASS_REDIRECT=https://app.myserver.example.com
# Admins emailed on each use (defaults to ADMIN_EMAILS). Also editable at runtime
# on the admin Settings page. Set empty to disable.
# BREAKGLASS_NOTIFY_EMAILS=oncall@example.com
# Optional webhook POSTed (JSON) on each use, e.g. an ntfy/Slack/Pushover URL.
# Also editable at runtime on the admin Settings page.
# BREAKGLASS_WEBHOOK_URL=
BREAKGLASS_WEBHOOK_TIMEOUT=5s
# Header/body text printed on the QR card PDF (per-code note adds to the body).
BREAKGLASS_PDF_HEADER=Emergency access
BREAKGLASS_PDF_BODY=Scan this code to gain temporary emergency access. Every use is logged and an administrator is notified.

# --- Rate limiting (count/window) ---
RATELIMIT_PER_EMAIL=5/15m
RATELIMIT_PER_IP=20/15m

# --- Storage / runtime ---
SQLITE_PATH=/data/auth.db
LISTEN_ADDR=:8080
# COOKIE_INSECURE=true        # dev only: drop the Secure cookie attribute when not behind TLS
