# vps-scaffold-auth configuration.
# Copy to apps/auth/.env in your server repo and fill in. Never commit the real
# .env — the deploy helper sets it to mode 600 on the server.

# --- Identity / authorization ---
# Public base URL of the auth service (the auth.<domain> site).
AUTH_PUBLIC_URL=https://auth.myserver.example.com
# Comma-separated domains whose verified email holders become regular users.
ALLOWED_EMAIL_DOMAINS=example.com,example.org
# Comma-separated explicit admin emails (granted the "admin" group).
ADMIN_EMAILS=alice@example.com
# Where to send users who arrive at login without a specific target.
DEFAULT_REDIRECT=https://app.myserver.example.com

# --- Session ---
# 32+ random bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Leading-dot domain so the session is shared across app subdomains.
# IMPORTANT: if DOMAIN is itself a subdomain (vps1.example.com), set this to
# .vps1.example.com — never widen it to a domain you don't fully control.
COOKIE_DOMAIN=.myserver.example.com
SESSION_TTL=12h
SESSION_RENEW_AFTER=6h

# --- One-time code ---
OTP_TTL=10m
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# --- Email delivery ---
EMAIL_BACKEND=smtp            # smtp | resend | log (log is for local/dev only)
EMAIL_FROM=Login <auth@example.com>
# smtp backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# resend backend
RESEND_API_KEY=

# --- Admin two-factor (optional) ---
TOTP_ENABLED=false
TOTP_ISSUER=myserver.example.com

# --- Rate limiting (count/window) ---
RATELIMIT_PER_EMAIL=5/15m
RATELIMIT_PER_IP=20/15m

# --- Storage / runtime ---
SQLITE_PATH=/data/auth.db
LISTEN_ADDR=:8080
# COOKIE_INSECURE=true        # dev only: drop the Secure cookie attribute when not behind TLS
