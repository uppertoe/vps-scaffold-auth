# Caddy config for the standalone example. {$DOMAIN} comes from the environment.
{
	# Uncomment and set a contact address for Let's Encrypt:
	# email you@example.com
}

# Reusable access guards. A protected site imports ONE of these; the LAST
# argument is the app's upstream address. The guard runs forward_auth and then
# reverse_proxies to that upstream with the shared session cookie stripped (see
# strip_auth_cookie), so a site needs no separate reverse_proxy line.
# Unauthenticated -> /verify returns 302 to the login page; a valid session ->
# 200 and Caddy forwards Remote-User / Remote-Email / Remote-Groups upstream
# (stripping client-supplied copies). A signed-in user who isn't allowed on this
# site is sent to a "no access" page with a sign-in link.
#
#   import protected whoami:80                        # any signed-in user (not break-glass)
#   import protected_domains "rch.org.au" app:3000    # signed-in user at a listed domain;
#                                                     #   login hints the domain + declines early
#   import protected_groups  "bg_stroke" app:3000     # a listed group, or a break-glass card
#                                                     #   whose target group is listed
#   import protected_admin app:3000                   # admins only; for a separate admin door
#   import protected_access  "rch.org.au" "dash_guests" app:3000   # in a listed domain OR group
#
# Any route that declares a domain (protected_domains, or protected_access) gives
# the login hint + early decline by that domain. Group-only routes
# (protected_groups, protected_admin) declare no domain, so they neither hint nor
# decline -- that's the door for people who can't match the domain. The domain
# door declines off-domain users (admins included), so give admins their own
# route via import protected_admin rather than the main gate.
#
# Break-glass QR sessions are deny-by-default: they reach only sites whose group
# list names the card's target group. Example of a per-route emergency entrance
# (the upstream argument rides on each import; no separate reverse_proxy line):
#
#   clinical.{$DOMAIN} {
#       @emergency path /code-stroke*
#       handle @emergency {
#           import protected_groups "bg_stroke" clinical:3000   # the laminated card opens here
#       }
#       handle {
#           import protected_domains "rch.org.au" clinical:3000 # staff, by email domain
#       }
#   }
#
# Some routes need no login at all (a webhook receiver, a health check, a public
# landing page). Give those a plain reverse_proxy and let a fallback handle
# protect the rest. Strip the cookie on the public route too: it's scoped to
# .{$DOMAIN}, so the browser sends it to every subdomain and path, and only a
# guard strips it automatically -- a plain reverse_proxy would hand the public
# backend the estate-wide session token. (header_up only scrubs the upstream
# request; it sends nothing to the browser, so it does NOT log anyone out.)
#
#   app.{$DOMAIN} {
#       @public path /webhooks/* /healthz
#       handle @public {
#           reverse_proxy app:3000 {
#               import strip_auth_cookie                        # public: no login, but still strip
#           }
#       }
#       handle {
#           import protected_domains "rch.org.au" app:3000      # everything else needs a login
#       }
#   }
#
# Each guard declares its requirement in ONE header, X-Auth-Policy, set with
# header_up -- which REPLACES any client-sent value, so a client can't inject or
# widen it. No per-guard "delete the rest" list to keep in sync: new policy
# fields go inside X-Auth-Policy. Grammar: ";"-separated key=value fields;
# "domains"/"groups" hold space/comma-separated lists; a bare "any" is the
# plain-protected sentinel. Label + alt-login are UX only (alt is re-validated
# server-side to be within the domain) and ride in their own plain headers. A
# custom guard that omits X-Auth-Policy is treated as plain `protected`.
(protected) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "any"
		}
		reverse_proxy {args[0]} {
			import strip_auth_cookie
		}
	}
}

(protected_domains) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "domains={args[0]}"
		}
		reverse_proxy {args[1]} {
			import strip_auth_cookie
		}
	}
}

# protected_domains, but shows a friendly label instead of listing the domains
# (handy when the list is long). Args: domains, label, upstream. The label slots
# into "This page is for <label> email addresses". The full list still governs
# the actual hint/decline.
(protected_domains_labeled) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "domains={args[0]}"
			header_up X-Auth-Domain-Label "{args[1]}"
		}
		reverse_proxy {args[2]} {
			import strip_auth_cookie
		}
	}
}

# protected_domains plus a small "sign in another way" link for users who can't
# match the domain. Args: domains, alt-login URL (absolute https within the
# server domain), link label, upstream.
(protected_domains_alt) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "domains={args[0]}"
			header_up X-Auth-Alt-Login "{args[1]}"
			header_up X-Auth-Alt-Label "{args[2]}"
		}
		reverse_proxy {args[3]} {
			import strip_auth_cookie
		}
	}
}

(protected_groups) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "groups={args[0]}"
		}
		reverse_proxy {args[1]} {
			import strip_auth_cookie
		}
	}
}

# Admin door: admins only, no login hint or early decline. Put it on a separate
# route/host so the app's main door can stay a pure domain gate.
(protected_admin) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "groups=admin"
		}
		reverse_proxy {args[0]} {
			import strip_auth_cookie
		}
	}
}

(protected_access) {
	route {
		import strip_client_identity
		forward_auth auth:8080 {
			uri /verify
			copy_headers Remote-User Remote-Email Remote-Groups
			header_up X-Auth-Policy "domains={args[0]};groups={args[1]}"
		}
		reverse_proxy {args[2]} {
			import strip_auth_cookie
		}
	}
}

# Strip the shared session cookie before the request reaches an app backend. The
# session cookie is scoped to .{$DOMAIN} so the browser sends it to every
# subdomain, and forward_auth proxies the original request (cookies included)
# upstream -- so without this an app backend would receive a live, estate-wide
# bearer credential it has no need for, and a single compromised app could replay
# it against every other app. Apps must read identity ONLY from the Remote-*
# headers (which forward_auth sets and Caddy strips from client input), never the
# cookie. The guards above import this automatically; it's also exposed for a
# hand-rolled reverse_proxy. Only vps_auth_session is removed; the app's own
# cookies are left intact.
(strip_auth_cookie) {
	header_up Cookie "(^|;\s*)vps_auth_session=[^;]*" ""
}

# Delete any client-supplied identity headers BEFORE forward_auth runs, so its
# copy_headers re-adds the authoritative values on a 2xx and an app can never see
# a spoofed Remote-*. MUST be imported inside a route {} (as the guards do) so it
# runs before forward_auth: Caddy's default order places a bare request_header
# AFTER forward_auth, which would instead delete the authoritative value. Verified
# against a live Caddy 2 forward_auth + whoami harness.
(strip_client_identity) {
	request_header -Remote-User
	request_header -Remote-Email
	request_header -Remote-Groups
}

# The login site. No auth in front of this — it IS the login. Overwrite
# X-Forwarded-For with the true peer so a client can't spoof the rate-limit key
# (Caddy otherwise preserves inbound X-Forwarded-For). Caddy faces clients
# directly here, so {remote_host} is the real client.
auth.{$DOMAIN} {
	reverse_proxy auth:8080 {
		header_up X-Forwarded-For {http.request.remote.host}
	}
}

# A protected demo app. Visit https://app.{$DOMAIN}: you'll be redirected to the
# login, and after signing in you'll see the Remote-* identity headers echoed.
# The session cookie is stripped before whoami sees it (folded into the guard).
app.{$DOMAIN} {
	import protected whoami:80
}
