# Caddy config for the standalone example. {$DOMAIN} comes from the environment.
{
	# Uncomment and set a contact address for Let's Encrypt:
	# email you@example.com
}

# Reusable access guards. A protected site imports ONE of these, then
# reverse_proxies its backend. Unauthenticated -> /verify returns 302 to the
# login page; a valid session -> 200 and Caddy forwards Remote-User /
# Remote-Email / Remote-Groups upstream (stripping client-supplied copies). A
# signed-in user who isn't allowed on this site is sent to a "no access" page
# with a sign-in link.
#
#   import protected                       # any signed-in user (not break-glass)
#   import protected_domains "rch.org.au"  # signed-in user at a listed domain;
#                                          #   login hints the domain + declines early
#   import protected_groups  "bg_stroke"   # a listed group, or a break-glass card
#                                          #   whose target group is listed
#   import protected_admin                 # admins only; for a separate admin door
#   import protected_access  "rch.org.au" "dash_guests"   # in a listed domain OR group
#
# Any route that declares a domain (protected_domains, or protected_access) gives
# the login hint + early decline by that domain. Group-only routes
# (protected_groups, protected_admin) declare no domain, so they neither hint nor
# decline -- that's the door for people who can't match the domain. The domain
# door declines off-domain users (admins included), so give admins their own
# route via import protected_admin rather than the main gate.
#
# Each guard sets the requirement headers it needs and deletes the rest, so a
# client can never inject X-Auth-Require-* to widen its own access. Break-glass
# QR sessions are deny-by-default: they reach only sites whose group list names
# the card's target group. Example of a per-route emergency entrance:
#
#   clinical.{$DOMAIN} {
#       @emergency path /code-stroke*
#       handle @emergency {
#           import protected_groups "bg_stroke"   # the laminated card opens here
#           reverse_proxy clinical:3000
#       }
#       handle {
#           import protected_domains "rch.org.au" # staff, by email domain
#           reverse_proxy clinical:3000
#       }
#   }
# Every guard fully controls the X-Auth-* namespace (sets what it needs, deletes
# the rest), so a client can't inject its own requirement or alt-login link.
(protected) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up -X-Auth-Require-Domains
		header_up -X-Auth-Require-Groups
		header_up -X-Auth-Alt-Login
		header_up -X-Auth-Alt-Label
	}
}

(protected_domains) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up X-Auth-Require-Domains "{args[0]}"
		header_up -X-Auth-Require-Groups
		header_up -X-Auth-Alt-Login
		header_up -X-Auth-Alt-Label
	}
}

# protected_domains plus a small "sign in another way" link for users who can't
# match the domain. Args: domains, alt-login URL (absolute https within the
# server domain), link label.
(protected_domains_alt) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up X-Auth-Require-Domains "{args[0]}"
		header_up -X-Auth-Require-Groups
		header_up X-Auth-Alt-Login "{args[1]}"
		header_up X-Auth-Alt-Label "{args[2]}"
	}
}

(protected_groups) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up -X-Auth-Require-Domains
		header_up X-Auth-Require-Groups "{args[0]}"
		header_up -X-Auth-Alt-Login
		header_up -X-Auth-Alt-Label
	}
}

# Admin door: admins only, no login hint or early decline. Put it on a separate
# route/host so the app's main door can stay a pure domain gate.
(protected_admin) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up -X-Auth-Require-Domains
		header_up X-Auth-Require-Groups "admin"
		header_up -X-Auth-Alt-Login
		header_up -X-Auth-Alt-Label
	}
}

(protected_access) {
	forward_auth auth:8080 {
		uri /verify
		copy_headers Remote-User Remote-Email Remote-Groups
		header_up X-Auth-Require-Domains "{args[0]}"
		header_up X-Auth-Require-Groups "{args[1]}"
		header_up -X-Auth-Alt-Login
		header_up -X-Auth-Alt-Label
	}
}

# The login site. No auth in front of this — it IS the login.
auth.{$DOMAIN} {
	reverse_proxy auth:8080
}

# A protected demo app. Visit https://app.{$DOMAIN}: you'll be redirected to the
# login, and after signing in you'll see the Remote-* identity headers echoed.
app.{$DOMAIN} {
	import protected
	reverse_proxy whoami:80
}
