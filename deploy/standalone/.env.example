# Copy to .env and fill in. This file is read by both the auth service
# (env_file) and by Caddy/compose for ${DOMAIN} substitution.
# The full annotated list of every setting is in ../.env.example.

# --- Required ---
# Your server domain. DNS for auth.<DOMAIN> and app.<DOMAIN> (or *.<DOMAIN>)
# must point at this host so Caddy can obtain certificates.
DOMAIN=example.com
# Public base URL of the auth (login) site.
AUTH_PUBLIC_URL=https://auth.example.com
# Where to send users who reach the login without a specific target.
DEFAULT_REDIRECT=https://app.example.com
# Who may sign in: domains become regular users; explicit admins get the admin UI.
ALLOWED_EMAIL_DOMAINS=example.com
ADMIN_EMAILS=you@example.com
# Leading-dot domain so the session cookie is shared across app subdomains.
COOKIE_DOMAIN=.example.com

# 32+ random bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Dedicated key that encrypts secrets at rest (break-glass tokens, TOTP seeds).
# Recommended: set this so rotating SESSION_SECRET doesn't break stored secrets.
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=

# --- Email delivery (how sign-in codes are sent) ---
EMAIL_BACKEND=smtp                  # smtp | resend | log
EMAIL_FROM=Login <auth@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# For the Resend backend instead of SMTP:
# RESEND_API_KEY=

# --- Optional (sensible defaults; see ../.env.example for all) ---
# TOTP_ENABLED=true                 # strongly recommended when using the admin UI
# SESSION_TTL=2h
# SESSION_REMEMBER_TTL=24h
# BREAKGLASS_SESSION_TTL=8h         # also editable at runtime on /admin/settings
# AUDIT_RETENTION=8760h             # login/app-access log retention; 0 = keep forever

# --- Local testing without a public domain ---
# Set DOMAIN=localhost and EMAIL_BACKEND=log (codes are printed to
# `docker compose logs auth`), add `tls internal` inside each site block of the
# Caddyfile so Caddy issues a local certificate, and map auth.localhost and
# app.localhost to 127.0.0.1 in /etc/hosts.
